#!/bin/bash
blocks=( "🬀" "🬁" "🬂" "🬃" "🬄" "🬅" "🬆" "🬇" "🬈" "🬉" "🬊" "🬋" "🬌" "🬍" "🬎" "🬏" "🬐" "🬑" "🬒" "🬓" "▌" "🬔" "🬕" "🬖" "🬗" "🬘" "🬙" "🬚" "🬛" "🬜" "🬝" "🬞" "🬟" "🬠" "🬡" "🬢" "🬣" "🬤" "🬥" "🬦" "🬧" "▐" "🬨" "🬩" "🬪" "🬫" "🬬" "🬭" "🬮" "🬯" "🬰" "🬱" "🬲" "🬳" "🬴" "🬵" "🬶" "🬷" "🬸" "🬹" "🬺" "🬻" "█" )
for i in $(seq 0 79); do
  r=$((i*255/79))
  g=$((255 - r))
  b=$((i*255/79))
  ch=${blocks[$((i % ${#blocks[@]}))]}
  printf "\x1b[38;2;%d;%d;%dm%s" "$r" "$g" "$b" "$ch"
done
printf "\x1b[0m\n"
for i in $(seq 0 25); do
  r=$((i*255/25))
  g=80
  b=$((255 - r))
  printf "\x1b[38;2;%d;%d;%dm%c " "$r" "$g" "$b" "$((65 + i))"
done
printf "\x1b[0mREGULAR TEXT\n"
